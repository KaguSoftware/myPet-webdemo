# PetPal environment — copy this file to `.env.local` and fill in the values,
# then restart the dev server. Both keys are required; without them the app
# shows a "Configuration needed" screen instead of loading.
#
# Find these in your Supabase project: Settings → API.
# The anon key is safe to expose to the browser (it's gated by Row Level Security).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — server-only. Enables the "Delete account" action (uses the Supabase
# admin API to remove the auth user, which cascades the household + all data).
# NEVER prefix this with NEXT_PUBLIC_. Without it, delete-account is disabled and
# the app tells the user so. Find it in Supabase: Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=
